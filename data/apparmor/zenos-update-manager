# AppArmor profile for Zen OS Update Manager
# Restricts to OSTree operations, network access, and update configuration.

abi <abi/4.0>,

include <tunables/global>

profile zenos-update-manager /usr/bin/zenos-update-manager {
  include <abstractions/base>
  include <abstractions/nameservice>

  # --- Capabilities ---
  capability sys_admin,
  capability dac_override,

  # --- Update Manager binary ---
  /usr/bin/zenos-update-manager mr,

  # --- OSTree ---
  /ostree/**              rw,
  /sysroot/ostree/**      rw,

  # --- Update configuration ---
  /etc/zenos/update/**    rw,

  # --- Network access for delta downloads ---
  network inet stream,
  network inet dgram,
  network inet6 stream,
  network inet6 dgram,

  # --- GPG signature verification ---
  /usr/bin/gpg*           ix,
  /usr/share/keyrings/**  r,

  # --- Shared libraries ---
  /usr/lib/**             mr,
  /usr/lib64/**           mr,

  # --- D-Bus system bus ---
  /run/dbus/system_bus_socket rw,

  # --- Deny sensitive paths ---
  deny /etc/shadow r,
  deny /etc/gshadow r,
  deny @{HOME}/** rw,
}
