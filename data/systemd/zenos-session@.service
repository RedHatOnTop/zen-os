[Unit]
Description=Zen OS User Session for %i
Documentation=https://github.com/nicejin/zen-os
After=systemd-logind.service zenos-compositor.service
Requires=zenos-compositor.service

[Service]
Type=simple
User=%i
Environment=XDG_RUNTIME_DIR=/run/user/%U
ExecStart=/usr/libexec/zenos-session
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical.target
